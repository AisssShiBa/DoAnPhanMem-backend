generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ROLES
//////////////////////////////////////////////////////

model Roles {
  id    Int    @id @default(autoincrement())
  name  String

  users Users[]
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model Users {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  phone           String?
  password_hash   String
  full_name       String?

  role_id         Int?
  provider        String?
  status          String?

  created_at      DateTime? @default(now())
  updated_at      DateTime? @default(now())

  verify_token    String?
  verify_expires  DateTime?

  school          String?
  major           String?

  reset_token     String?
  reset_expires   DateTime?

  is_deleted      Boolean?  @default(false)
  deleted_at      DateTime?

  role            Roles? @relation(fields: [role_id], references: [id])

  refresh_tokens  refresh_tokens[]
  notifications   User_Notifications[]
  logs            Activity_Logs[]
  settings        User_Settings?

  tags            Tags[]
  categories      Categories[]
  tasks           Tasks[]
  reminders       Reminders[]
}

//////////////////////////////////////////////////////
// USER NOTIFICATIONS
//////////////////////////////////////////////////////

model User_Notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int?

  title      String?
  content    String?
  type       String?

  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now())

  user Users? @relation(fields: [user_id], references: [id])
}

//////////////////////////////////////////////////////
// ACTIVITY LOGS
//////////////////////////////////////////////////////

model Activity_Logs {
  id         Int       @id @default(autoincrement())
  user_id    Int?

  action     String?
  created_at DateTime? @default(now())

  user Users? @relation(fields: [user_id], references: [id])
}

//////////////////////////////////////////////////////
// USER SETTINGS
//////////////////////////////////////////////////////

model User_Settings {
  user_id                Int      @id
  theme                  String?
  notification_enabled   Boolean? @default(true)
  language               String?
  timezone               String?

  user Users @relation(fields: [user_id], references: [id])
}

//////////////////////////////////////////////////////
// TAGS
//////////////////////////////////////////////////////

model Tags {
  id         Int      @id @default(autoincrement())
  user_id    Int?

  name       String?
  color_code String?

  is_deleted Boolean? @default(false)

  user Users? @relation(fields: [user_id], references: [id])

  task_tags Task_Tags[]
}

//////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////

model Categories {
  id            Int       @id @default(autoincrement())
  user_id       Int?

  color_code    String?
  name          String?
  display_order Int?

  is_deleted    Boolean?  @default(false)

  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())

  user Users? @relation(fields: [user_id], references: [id])

  tasks Tasks[]

  @@index([user_id, is_deleted])
}

//////////////////////////////////////////////////////
// TASKS
//////////////////////////////////////////////////////

model Tasks {
  id            Int       @id @default(autoincrement())

  user_id       Int?
  category_id   Int?

  title         String
  description   String?

  start_date    DateTime?
  due_date      DateTime?

  priority      Int?
  status        String?

  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())

  is_deleted    Boolean?  @default(false)
  deleted_at    DateTime?

  completed_at  DateTime?

  user Users? @relation(fields: [user_id], references: [id])

  category Categories? @relation(fields: [category_id], references: [id])

  reminders   Reminders[]
  subtasks    SubTasks[]
  task_tags   Task_Tags[]
  attachments Task_Attachments[]

  @@index([user_id, due_date, is_deleted])
  @@index([user_id, status, is_deleted])
}

//////////////////////////////////////////////////////
// REMINDERS
//////////////////////////////////////////////////////

model Reminders {
  id          Int       @id @default(autoincrement())

  user_id     Int?
  task_id     Int?

  remind_time DateTime?
  status      String?

  task Tasks? @relation(fields: [task_id], references: [id])
  user Users? @relation(fields: [user_id], references: [id])
}

//////////////////////////////////////////////////////
// TASK TAGS
//////////////////////////////////////////////////////

model Task_Tags {
  task_id Int
  tag_id  Int

  task Tasks @relation(fields: [task_id], references: [id])
  tag  Tags  @relation(fields: [tag_id], references: [id])

  @@id([task_id, tag_id])
}

//////////////////////////////////////////////////////
// SUB TASKS
//////////////////////////////////////////////////////

model SubTasks {
  id            Int       @id @default(autoincrement())

  task_id       Int?
  title         String?
  status        String?

  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())
  completed_at  DateTime?

  task Tasks? @relation(fields: [task_id], references: [id])
}

//////////////////////////////////////////////////////
// TASK ATTACHMENTS
//////////////////////////////////////////////////////

model Task_Attachments {
  id         Int       @id @default(autoincrement())
  task_id    Int?

  file_name  String
  file_url   String

  file_size  Int?
  mime_type  String?

  created_at DateTime? @default(now())

  task Tasks? @relation(fields: [task_id], references: [id])
}

//////////////////////////////////////////////////////
// REFRESH TOKENS
//////////////////////////////////////////////////////

model refresh_tokens {
  id          String   @id @default(cuid())

  user_id     Int
  token       String   @unique

  expires_at  DateTime

  device_info String?
  ip_address  String?

  created_at  DateTime @default(now())

  user Users @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token])
}